# SMS Provider Configuration
# Copy this file to .env and update with your credentials

# MTN Zambia SMS API (current implementation)
MTN_API_URL=https://your-mtn-api-endpoint.com
MTN_API_KEY=your-mtn-api-key
MTN_USERNAME=your-mtn-username
MTN_PASSWORD=your-mtn-password

# Twilio (if using Twilio provider)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# AWS SNS (if using AWS provider)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
